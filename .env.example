# ======================================================================
# VocaFlow Environment Variables (template)
# - 실제 값은 .env.local 에 복사 후 채워넣기 (커밋 금지)
# - MCP 서버는 이 변수들을 ${env:...} 플레이스홀더로 참조
# ======================================================================

# --- Supabase ---------------------------------------------------------
# Supabase MCP용 Personal Access Token
# 발급: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# 프로젝트 클라이언트 키 (Renderer/Web용)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 서버 전용 서비스 롤 키 (임포트 스크립트 등 Main Process 전용)
SUPABASE_SERVICE_ROLE_KEY=

# --- GitHub -----------------------------------------------------------
# PAT: repo, workflow, read:org 권한 권장
# 발급: https://github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Netlify ----------------------------------------------------------
# 발급: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# --- 외부 사전 API (Phase 4) ------------------------------------------
# Merriam-Webster Learner's Dictionary
MW_LEARNERS_API_KEY=

# 네이버 Papago (한글 뜻)
NAVER_PAPAGO_CLIENT_ID=
NAVER_PAPAGO_CLIENT_SECRET=

# 국립국어원 표준국어대사전 (공공데이터포털)
KOREAN_DICT_API_KEY=
