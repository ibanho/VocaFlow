{
  "name": "vocaflow",
  "version": "0.1.0",
  "description": "VocaFlow — 고2 수능 영어 정복을 위한 라이트너 시스템 기반 스마트 단어장",
  "productName": "VocaFlow",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.22.0"
  },
  "volta": {
    "node": "24.11.1"
  },
  "scripts": {
    "dev": "quasar dev",
    "build": "quasar build",
    "build:pwa": "quasar build -m pwa",
    "lint": "eslint --cache --cache-location=.eslintcache \"src/**/*.{ts,vue}\"",
    "format": "prettier --write \"src/**/*.{ts,vue,css,scss}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.12",
    "@supabase/supabase-js": "^2.45.0",
    "pinia": "^2.2.0",
    "quasar": "^2.17.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^2.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.0",
    "typescript": "~5.6.0",
    "vite-plugin-checker": "^0.8.0",
    "vitest": "^2.1.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.1.0"
  }
}
